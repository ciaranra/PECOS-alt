# Set default behavior to automatically normalize line endings to LF
* text=auto eol=lf

# Julia files should always use LF
*.jl text eol=lf
*.toml text eol=lf

# Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.dll binary
*.so binary
*.dylib binary
*.exe binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
